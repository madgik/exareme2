#print(f"\n1. node1_datapoints-> {node1_datapoints}")
indices=np.array([row_index for row_index in range(node1_datapoints.shape[0])])
node1_datapoints=np.insert(node1_datapoints,0,indices,axis=1)
#print(f"\n2. node1_datapoints-> {node1_datapoints}")

colx_node2_region1=[random.uniform(r1_min_x,r1_max_x) for i in range(num_of_datapoints_per_node_per_region)]
colx_node2_region2=[random.uniform(r2_min_x,r2_max_x) for i in range(num_of_datapoints_per_node_per_region)]
colx_node2_region3=[random.uniform(r3_min_x,r3_max_x) for i in range(num_of_datapoints_per_node_per_region)]
colx_node2=colx_node2_region1+colx_node2_region2+colx_node2_region3
coly_node2_region1=[random.uniform(r1_min_y,r1_max_y) for i in range(num_of_datapoints_per_node_per_region)]
coly_node2_region2=[random.uniform(r2_min_y,r2_max_y) for i in range(num_of_datapoints_per_node_per_region)]
coly_node2_region3=[random.uniform(r3_min_y,r3_max_y) for i in range(num_of_datapoints_per_node_per_region)]
coly_node2=coly_node2_region1+coly_node2_region2+coly_node2_region3
colz_node2_region1=[random.uniform(r1_min_z,r1_max_z) for i in range(num_of_datapoints_per_node_per_region)]
colz_node2_region2=[random.uniform(r2_min_z,r2_max_z) for i in range(num_of_datapoints_per_node_per_region)]
colz_node2_region3=[random.uniform(r3_min_z,r3_max_z) for i in range(num_of_datapoints_per_node_per_region)]
colz_node2=colz_node2_region1+colz_node2_region2+colz_node2_region3
node2_datapoints=np.array([colx_node2,coly_node2,colz_node2]).T
indices=np.array([row_index for row_index in range(node2_datapoints.shape[0])])
node2_datapoints=np.insert(node2_datapoints,0,indices,axis=1)

colx_node3_region1=[random.uniform(r1_min_x,r1_max_x) for i in range(num_of_datapoints_per_node_per_region)]
colx_node3_region2=[random.uniform(r2_min_x,r2_max_x) for i in range(num_of_datapoints_per_node_per_region)]
colx_node3_region3=[random.uniform(r3_min_x,r3_max_x) for i in range(num_of_datapoints_per_node_per_region)]
colx_node3=colx_node3_region1+colx_node3_region2+colx_node3_region3
coly_node3_region1=[random.uniform(r1_min_y,r1_max_y) for i in range(num_of_datapoints_per_node_per_region)]
coly_node3_region2=[random.uniform(r2_min_y,r2_max_y) for i in range(num_of_datapoints_per_node_per_region)]
coly_node3_region3=[random.uniform(r3_min_y,r3_max_y) for i in range(num_of_datapoints_per_node_per_region)]
coly_node3=coly_node3_region1+coly_node3_region2+coly_node3_region3
colz_node3_region1=[random.uniform(r1_min_z,r1_max_z) for i in range(num_of_datapoints_per_node_per_region)]
colz_node3_region2=[random.uniform(r2_min_z,r2_max_z) for i in range(num_of_datapoints_per_node_per_region)]
colz_node3_region3=[random.uniform(r3_min_z,r3_max_z) for i in range(num_of_datapoints_per_node_per_region)]
colz_node3=colz_node3_region1+colz_node3_region2+colz_node3_region3
node3_datapoints=np.array([colx_node3,coly_node3,colz_node3]).T
indices=np.array([row_index for row_index in range(node3_datapoints.shape[0])])
node3_datapoints=np.insert(node3_datapoints,0,indices,axis=1)



#data_points=ListOfNpArrays([np.array(node1_datapoints[:,0]),np.array(node1_datapoints[:,1]),np.array(node1_datapoints[:,2])])
#data_points=np.concatenate([node1_datapoints,node2_datapoints,node3_datapoints])
#print(f"data_points -> {data_points}")
print(f"\n(script) node1_datapoints -> {node1_datapoints}\n")

num_of_clusters=3
num_of_dimensions=3
initial_centroids=generate_initial_centroids(num_of_dimensions,num_of_clusters,-5,5)
print(f"\n(script) initial centroids-> {initial_centroids}")
#pprint(initial_centroids);print("")

import time
start_time=time.time()

num_of_iterations=10
centroids=initial_centroids
#print(f"\ncentroids -> {centroids}\n")
for i in range(num_of_iterations):
    centroids=centroids.as_numpy_array()
    print(f"\n(script) centroids -> {centroids}\n")

    #d1_tmp=np.tile(node1_datapoints.T,centroids.shape[1]).T
    d1_tmp=np.tile(node1_datapoints.T,centroids.shape[0]).T
    print(f"\n(script) d1_tmp -> {d1_tmp}\n")
    #c1_tmp=np.repeat(centroids.T,d1_tmp.shape[0],axis=0)
    #c1_tmp=np.repeat(centroids.T,centroids.shape[1],axis=0)
    c_tmp=np.repeat(centroids,node1_datapoints.shape[0],axis=0) #centroids.shape[1],axis=0)
    print(f"\n(script) c_tmp -> {c_tmp}\n")
    #pdb.set_trace()
    cross_product_node1=np.concatenate([d1_tmp,c_tmp],axis=1)
    print(f"\n(script) cross_product_node1 -> {cross_product_node1}")
    
    tmp=np.split(cross_product_node1.T,cross_product_node1.shape[1])
    tmp=[l.flatten() for l in tmp]
    print(f"\n(script) tmp -> {tmp}")
    #pdb.set_trace()
    cross_product_node1=ListOfNpArrays([i for i in tmp])
    #cross_product_node1=ListOfNpArrays([col for col in cross_product_node1])
    print(f"\n(script) cross_product_node1 -> {cross_product_node1}\n")
    new_centroids_node1=local_calc(cross_product_node1)


    #d2_tmp=np.tile(node2_datapoints.T,len(centroids)).T
    d2_tmp=np.tile(node2_datapoints.T,centroids.shape[0]).T
    c2_tmp=np.repeat(centroids,node2_datapoints.shape[0],axis=0) #centroids.shape[1],axis=0)
    #c2_tmp=np.repeat(centroids,len(node2_datapoints),axis=0)
    cross_product_node2=np.concatenate([d2_tmp,c2_tmp],axis=1)
    tmp=np.split(cross_product_node2.T,cross_product_node2.shape[1])
    tmp=[l.flatten() for l in tmp]
    cross_product_node2=ListOfNpArrays([i for i in tmp])
    new_centroids_node2=local_calc(cross_product_node2)


    d3_tmp=np.tile(node3_datapoints.T,centroids.shape[0]).T
    c3_tmp=np.repeat(centroids,node3_datapoints.shape[0],axis=0) #centroids.shape[1],axis=0)
    #c2_tmp=np.repeat(centroids,len(node2_datapoints),axis=0)
    cross_product_node3=np.concatenate([d3_tmp,c3_tmp],axis=1)
    tmp=np.split(cross_product_node3.T,cross_product_node3.shape[1])
    tmp=[l.flatten() for l in tmp]
    cross_product_node3=ListOfNpArrays([i for i in tmp])
    new_centroids_node3=local_calc(cross_product_node3)
    print(f"\n(script) \nnew_centroids_node1 -> {new_centroids_node1}")
    print(f"\n(script) \nnew_centroids_node2 -> {new_centroids_node2}")
    print(f"\n(script) \nnew_centroids_node3 -> {new_centroids_node3}")
    #pdb.set_trace()

    local_centroids=new_centroids_node1+new_centroids_node2+new_centroids_node3

    print(f"\n(script) local_centroids -> {local_centroids}\n")
    #pdb.set_trace()
    centroids=global_calc(num_of_clusters,local_centroids)#[new_centroids_node1,new_centroids_node2,new_centroids_node3])

#print(f"num_of_iterations={num_of_iterations} num_of_datapoints_per_node_per_region={num_of_datapoints_per_node_per_region} TIME---> {time.time() - start_time} seconds")

print("FINAL centroids->")
pprint(centroids)

