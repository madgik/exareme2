class AlgorithmInfo:
    def __init__(self,name,functions):
        print(f"\nfunctions->    {functions}\n")
        print(f"\ntype(functions)->    {type(functions)}\n")
        print(f'\nfunctions["_global"]->    {functions["_global"]}\n')
        self.name=name
        self.functions=functions

        print(f"\nself.functions-> {self.functions}\n")
        print(f"\nfunctions-> {functions}\n")

    def __repr__(self):
        return f"<name:{self.name}>"# functions->{self.functions}>"

def get_annotations(func):
    parameters = inspect.signature(func).parameters
    annotations = func.__annotations__

    parameters = dict(parameters)
    if len(parameters) != len(annotations) - 1:  # subtract return annotation
        msg = "This method should be fully annotated. "
        msg += f"Some annotations are missing: {annotations}"
        raise SyntaxError(msg)
    return annotations

