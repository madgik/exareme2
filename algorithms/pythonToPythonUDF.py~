def get_function_header(function_name): #inspect.getsource(kmeans._local)

    source=inspect.getsource(function_name)
    source_split=source.split("\n",1)
    function_header=source_split[0]

    return function_header

def get_function_body(function_name): #inspect.getsource(kmeans._local)

    source=inspect.getsource(function_name)
    source_split=source.split("\n",1)
    function_header=source_split[0]
    function_body=source_split[1]

    return function_body

def get_algorithm_info(json_filename):
    with open(json_filename,"r") as json_file:
        data=json.loads(json_file.read())
        print(f"data->{data}")
        algorithm_info=AlgorithmInfo(**data)
        print(f"algorithm_info->{algorithm_info}")
    return algorithm_info

