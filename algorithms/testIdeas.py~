def create_local_view(db_connection,view_table_name):
    cursor=db_connection.cursor()
    query=f"CREATE VIEW {view_table_name} AS SELECT * FROM {data_table}"
    print(f"\n(create_local_view) db={db_connection.mapi.database} query={query}")
    cursor.execute(query)
    
    register_view(db_connection,view_table_name)

def create_remote_table():
    cursor=db_connections["global"].cursor()

