def generate_table_name(table_name):
    return "{}_{}".format(table_name,datetime.datetime.now().microsecond * (random.randrange(1, 100 ))//10000)

def register_table(db_connection,table_name):
    #print(f"(register_table) {db_connection.mapi.database} {table_name} pprint->")
    print(created_tables)
    if not created_tables["local"]:
        created_tables["local"][db_connection.mapi.database]=[]
    if db_connection.mapi.database not in created_tables["local"]:
        created_tables["local"][db_connection.mapi.database]=[]
    created_tables["local"][db_connection.mapi.database].append((db_connection,table_name))

def register_view(db_connection,view_name):
    if not created_views["local"]:
        created_views["local"][db_connection.mapi.database]=[]
    if db_connection.mapi.database not in created_views["local"]:
        created_views["local"][db_connection.mapi.database]=[]
    created_views["local"][db_connection.mapi.database].append((db_connection,view_name))

