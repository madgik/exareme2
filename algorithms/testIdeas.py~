        print(f"EXCEPTION: there is no {function_name} function in file {python_function_file}")
    
    
    udf_string="CREATE OR REPLACE FUNCTION my_python_udf(avar INT, anothervar INT) RETURNS TABLE(resultc1 INT,resultc2 INT) LANGUAGE PYTHON {\n"
