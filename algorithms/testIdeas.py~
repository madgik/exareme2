def establish_databases_connections():
    #print("(establish_databases_connections) started...")
    db_connections["global"]=pymonetdb.connect(username="monetdb",password="monetdb",hostname=global_db["hostname"],database=global_db["name"],autocommit=True)
    
    for db in local_dbs:
        #connection=pymonetdb.connect(username="monetdb",password="monetdb",hostname=db["hostname"],database=db["name"],autocommit=True)
        connection=pymonetdb.sql.connections.Connection(username="monetdb",password="monetdb",hostname=db["hostname"],database=db["name"],autocommit=True)
        db_connections["local"].append(connection)
    #print("\n(establish_databases_connections) finished")

