import random
import matplotlib.pyplot as plt
import numpy as np
from kmeans_mult_dim import _local,_global

from pprint import pprint

#3 Nodes
#Generate datapoints for the nodes
#For each node, random datapoints will be ghenerated in 3 regions
#region1: x in [20,55), y in [10,55), z in [0,5)
r1_min_x=20;r1_max_x=55;
r1_min_y=10;r1_max_y=55;
r1_min_z=0;r1_max_z=5;
#region2: x in [-50,-10), y in [10,55), z in [5,10)
r2_min_x=-50;r2_max_x=-10;
r2_min_y=10;r2_max_y=55;
r2_min_z=5;r2_max_z=10;
#region3: x in [-50,-10), y in [-50,-10), z in [-5,0)
r3_min_x=-50;r3_max_x=-10;
r3_min_y=-50;r3_max_y=-10;
r3_min_z=-5;r3_max_z=0;

num_of_datapoints_per_node_per_region=200

colx_node1_region1=[random.uniform(r1_min_x,r1_max_x) for i in range(num_of_datapoints_per_node_per_region)]
colx_node1_region2=[random.uniform(r2_min_x,r2_max_x) for i in range(num_of_datapoints_per_node_per_region)]
colx_node1_region3=[random.uniform(r3_min_x,r3_max_x) for i in range(num_of_datapoints_per_node_per_region)]
colx_node1=colx_node1_region1+colx_node1_region2+colx_node1_region3
coly_node1_region1=[random.uniform(r1_min_y,r1_max_y) for i in range(num_of_datapoints_per_node_per_region)]
coly_node1_region2=[random.uniform(r2_min_y,r2_max_y) for i in range(num_of_datapoints_per_node_per_region)]
coly_node1_region3=[random.uniform(r3_min_y,r3_max_y) for i in range(num_of_datapoints_per_node_per_region)]
coly_node1=coly_node1_region1+coly_node1_region2+coly_node1_region3
colz_node1_region1=[random.uniform(r1_min_z,r1_max_z) for i in range(num_of_datapoints_per_node_per_region)]
colz_node1_region2=[random.uniform(r2_min_z,r2_max_z) for i in range(num_of_datapoints_per_node_per_region)]
colz_node1_region3=[random.uniform(r3_min_z,r3_max_z) for i in range(num_of_datapoints_per_node_per_region)]
colz_node1=colz_node1_region1+colz_node1_region2+colz_node1_region3
node1_datapoints=np.array([colx_node1,coly_node1,colz_node1]).T

colx_node2_region1=[random.uniform(r1_min_x,r1_max_x) for i in range(num_of_datapoints_per_node_per_region)]
colx_node2_region2=[random.uniform(r2_min_x,r2_max_x) for i in range(num_of_datapoints_per_node_per_region)]
colx_node2_region3=[random.uniform(r3_min_x,r3_max_x) for i in range(num_of_datapoints_per_node_per_region)]
colx_node2=colx_node2_region1+colx_node2_region2+colx_node2_region3
coly_node2_region1=[random.uniform(r1_min_y,r1_max_y) for i in range(num_of_datapoints_per_node_per_region)]
coly_node2_region2=[random.uniform(r2_min_y,r2_max_y) for i in range(num_of_datapoints_per_node_per_region)]
coly_node2_region3=[random.uniform(r3_min_y,r3_max_y) for i in range(num_of_datapoints_per_node_per_region)]
coly_node2=coly_node2_region1+coly_node2_region2+coly_node2_region3
colz_node2_region1=[random.uniform(r1_min_z,r1_max_z) for i in range(num_of_datapoints_per_node_per_region)]
colz_node2_region2=[random.uniform(r2_min_z,r2_max_z) for i in range(num_of_datapoints_per_node_per_region)]
colz_node2_region3=[random.uniform(r3_min_z,r3_max_z) for i in range(num_of_datapoints_per_node_per_region)]
colz_node2=colz_node2_region1+colz_node2_region2+colz_node2_region3
node2_datapoints=np.array([colx_node2,coly_node2,colz_node2]).T

colx_node3_region1=[random.uniform(r1_min_x,r1_max_x) for i in range(num_of_datapoints_per_node_per_region)]
colx_node3_region2=[random.uniform(r2_min_x,r2_max_x) for i in range(num_of_datapoints_per_node_per_region)]
colx_node3_region3=[random.uniform(r3_min_x,r3_max_x) for i in range(num_of_datapoints_per_node_per_region)]
colx_node3=colx_node3_region1+colx_node3_region2+colx_node3_region3
coly_node3_region1=[random.uniform(r1_min_y,r1_max_y) for i in range(num_of_datapoints_per_node_per_region)]
coly_node3_region2=[random.uniform(r2_min_y,r2_max_y) for i in range(num_of_datapoints_per_node_per_region)]
coly_node3_region3=[random.uniform(r3_min_y,r3_max_y) for i in range(num_of_datapoints_per_node_per_region)]
coly_node3=coly_node3_region1+coly_node3_region2+coly_node3_region3
colz_node3_region1=[random.uniform(r1_min_z,r1_max_z) for i in range(num_of_datapoints_per_node_per_region)]
colz_node3_region2=[random.uniform(r2_min_z,r2_max_z) for i in range(num_of_datapoints_per_node_per_region)]
colz_node3_region3=[random.uniform(r3_min_z,r3_max_z) for i in range(num_of_datapoints_per_node_per_region)]
colz_node3=colz_node3_region1+colz_node3_region2+colz_node3_region3
node3_datapoints=np.array([colx_node3,coly_node3,colz_node3]).T


num_of_clusters=3
num_of_dimensions=3
initial_centroids=_global(num_of_dimensions,num_of_clusters,[])
print("initial centroids->")
pprint(initial_centroids)

import time
start_time=time.time()

num_of_iterations=1000
centroids=initial_centroids
for i in range(num_of_iterations):
    new_centroids_node1=_local(centroids,node1_datapoints)
    #print(f"new_centroids_node1->{new_centroids_node1}")
    new_centroids_node2=_local(centroids,node2_datapoints)
    #print(f"new_centroids_node2->{new_centroids_node2}")
    new_centroids_node3=_local(centroids,node3_datapoints)
    #print(f"new_centroids_node3->{new_centroids_node3}")
    
    #all_new_centroids=[new_centroids_node1,new_centroids_node2,new_centroids_node3]
    #print(f"all_new_centroids-------------->{all_new_centroids}")
    #pdb.set_trace()
    centroids=_global(num_of_dimensions,num_of_clusters,[new_centroids_node1,new_centroids_node2,new_centroids_node3])


print(f"num_of_iterations={num_of_iterations} num_of_datapoints_per_node_per_region={num_of_datapoints_per_node_per_region} TIME---> {time.time() - start_time} seconds")

print("FINAL centroids->")
pprint(centroids)

#plottinng--------------------------------------------------------------------------------------
fig = plt.figure()
ax = fig.gca(projection='3d')
ax.set_xlabel('x');ax.set_ylabel('y');ax.set_zlabel('z')

ax.scatter(node1_datapoints[:,0],node1_datapoints[:,1],node1_datapoints[:,2],c='c',marker='d')
ax.scatter(node2_datapoints[:,0],node2_datapoints[:,1],node2_datapoints[:,2],c='m',marker='s')
ax.scatter(node3_datapoints[:,0],node3_datapoints[:,1],node3_datapoints[:,2],c='y',marker='o')
ax.scatter(initial_centroids[:,0],initial_centroids[:,1],initial_centroids[:,2],depthshade=False,c='r',marker='x',s=150)
ax.scatter(centroids[:,0],centroids[:,1],centroids[:,2],depthshade=False,c='g',marker='x',s=150)
ax.set_zlim(-5,15)
#figManager = plt.get_current_fig_manager())
#figManager.window.showMaximized()
plt.show()

