def zeros(num_of_rows,num_of_cols,dtype=float):
    a=[np.zeros((num_of_cols,1),dtype=dtype) for i in range(num_of_rows)]
    l=ListOfNpArrays(a)
    return l

def sum_cols(l):
    return ListOfNpArrays(sum(l))
        
def sum_rows(l):
    num_of_cols=l.get_num_cols()
    r=np.zeros((num_of_cols,1))
    for i in range(num_of_cols):
        r[i]=sum(l[i])
    return ListOfNpArrays(r)

def to_ListOfNpArrays(l:np.array):
#    print(f"(ListOfNpArrays::to_ListOfNpArrays) l-> {l}")
#    print(f"(ListOfNpArrays::to_ListOfNpArrays) l[:,0]-> {l[:,0]}")
    transformed=[]
    for col_index in range(l.shape[1]):
        transformed.append(l[:,col_index])
    return ListOfNpArrays(transformed)
