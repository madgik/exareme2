@startuml
actor App 
box "Runtime"
participant Orchestrator
database GlobalNode
database LocalNodes
end box

App -[#green]> Orchestrator: Request:\nAlgorithm, test data, tfilters, transformation, ...
Orchestrator -[#blue]-> GlobalNode: Control:\nRetrieve saved model
GlobalNode -[#red]> LocalNodes: Data Transfer:\nModel
LocalNodes -[#red]> LocalNodes: Transform:\nApply Model.predict() to data
LocalNodes -[#red]> GlobalNode: Data Transfer:\nMerge local results
Orchestrator -[#green]> App: Response:\nFinal result
@enduml

