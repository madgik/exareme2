@startuml
actor App 
box "Runtime"
participant Orchestrator
database TrainingLocalNodes
database GlobalNode
database TestingLocalNode
end box


App -[#green]> Orchestrator: Request:\nAlgorithm, data, filters, ...

loop over LocalNodes
    ref over TrainingLocalNodes, GlobalNode :Training phase
    ref over TestingLocalNode, GlobalNode :Testing phase
end

Orchestrator -[#green]> App: Response:\nFinal result
@enduml
